PORT=5000
NODE_ENV=production

# Firebase Configuration (use individual env vars — do NOT upload the JSON file)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# Email Service (Nodemailer)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads/receipts

# Reminder Configuration
REMINDER_DAYS_BEFORE=3,1,0

# Frontend URL (comma-separated list of allowed CORS origins)
# On Railway, set this to your Vercel frontend URL
FRONTEND_URL=https://your-app.vercel.app,http://localhost:5173